@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find required dependencies
if(WIN32)
    if(@USE_RTAUDIO@)
        find_dependency(RtAudio)
    endif()
    if(@USE_RTMIDI@)
        find_dependency(RtMidi)
    endif()
    find_dependency(SndFile)
else()
    find_package(PkgConfig REQUIRED)
    if(@USE_RTAUDIO@)
        pkg_check_modules(RTAUDIO REQUIRED rtaudio)
    endif()
    if(@USE_RTMIDI@)
        pkg_check_modules(RTMIDI REQUIRED rtmidi)
    endif()
    pkg_check_modules(SNDFILE REQUIRED sndfile)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/miniaudioengine-targets.cmake")

check_required_components(miniaudioengine)