{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "miniaudioengine: cmake configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
            ],
            "group": "build",
        },
        {
            "label": "miniaudioengine: cmake build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "miniaudioengine: cmake configure",
        },
        {
            "label": "aws: start instance",
            "type": "shell",
            "command": "aws ec2 start-instances --instance-ids i-00b5319ac43a780e6",
            "windows": {
                "command": "aws ec2 start-instances --instance-ids i-00b5319ac43a780e6"
            }
        },
        {
            "label": "aws: stop instance",
            "type": "shell",
            "command": "aws ec2 stop-instances --instance-ids i-00b5319ac43a780e6",
            "windows": {
                "command": "aws ec2 stop-instances --instance-ids i-00b5319ac43a780e6"
            }
        },
        {
            "label": "aws: start build",
            "type": "shell",
            "command": "aws codebuild start-build --project-name miniaudioengine",
            "group": "build"
        },
        {
            "label": "sam: build and deploy",
            "type": "shell",
            "command": "sam build; sam deploy",
            "group": "build"
        },
        {
            "label": "sam: list stack outputs",
            "type": "shell",
            "command": "sam list stack-outputs --stack-name miniaudioengine"
        },
        {
            "label": "aws: start build",
            "type": "shell",
            "command": "aws codebuild start-build --project-name miniaudioengine",
            "group": "build"
        }
    ]
}
