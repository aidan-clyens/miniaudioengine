{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "device-info",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/device-info/src/device-info",
            "linux": {
                "program": "${workspaceFolder}/build/examples/device-info/src/device-info",
                "args": [
                    "--verbose"
                ],
                "miDebuggerPath": "/usr/bin/gdb",
                "MIMode": "gdb",
            },
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "wav-audio-player",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/wav-audio-player/src/wav-audio-player",
            "linux":{
                "program": "${workspaceFolder}/build/examples/wav-audio-player/src/wav-audio-player",
                "args": ["--set-audio-output", "130", "--input-file", "./samples/test.wav", "--verbose"],
                "miDebuggerPath": "/usr/bin/gdb",
                "MIMode": "gdb",
            },
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "wav-audio-player (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\build\\examples\\wav-audio-player\\src\\Debug\\wav-audio-player.exe",
            "args": [
                "--set-audio-output",
                "130",
                "--input-file",
                ".\\samples\\test.wav",
                "--verbose"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal"
        },
        {
            "name": "miniaudioengine-unit-tests (Windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/tests/unit/Debug/miniaudioengine-unit-tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal"
        },
    ]
}